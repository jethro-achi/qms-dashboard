# .env.example  —  copy to .env.local and fill in. NEVER commit real secrets.

# ---- Auth.js -----------------------------------------------------------------
# Generate with: openssl rand -base64 32  (this is a TEMPLATE — put real values
# in .env.local, which is what Next.js loads; .env.example is never loaded.)
AUTH_SECRET="replace-with-a-long-random-string"
# Session lifetime in seconds (default 1800 = 30 min).
SESSION_MAX_AGE=1800
# Account lockout policy.
AUTH_MAX_FAILED=5
AUTH_LOCKOUT_MINUTES=15

# ---- QMS database (READ-ONLY replica) ----------------------------------------
# Point this at a READ REPLICA, never the primary OLTP node, so the dashboard's
# aggregate scans never compete with the live queue system. The app only SELECTs
# (grant SELECT on banktickets/branches/queues/counters/users/logs — see
# db/schema.sql PART A, which also lists the indexes to add for large tables).
QMS_DB_HOST=localhost
QMS_DB_PORT=3306
QMS_DB_USER=qms_user
QMS_DB_PASSWORD=Qms@12345
QMS_DB_NAME=qms
QMS_DB_POOL=10
# Paste the DB server's CA cert (PEM) to force verified TLS. Leave unset only
# if the DB link is already on a trusted private segment.
# QMS_DB_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# ---- QMS performance tuning (matters at millions of rows) --------------------
# Default date window (days) applied when the user hasn't picked a range. 0 = all
# history (fine for small/demo datasets). On a high-volume bank set 30 or 90 so
# each dashboard load scans a bounded slice instead of the whole fact table. The
# user can always widen the range via the filter bar.
#   NOTE: anchored to "now" — if your QMS data lags real time by more than this,
#   the dashboard looks empty until you widen the filter. Tune to your data.
QMS_DEFAULT_LOOKBACK_DAYS=0
# In-process cache TTL (seconds) for aggregate analytics. Collapses repeat loads
# and rapid filter toggling into one DB round-trip per window; 0 disables it.
QMS_CACHE_TTL=30
# SLA threshold (seconds) and display timezone offset for the QMS data.
QMS_SLA_SECONDS=300
QMS_TZ_OFFSET=+00:00

# ---- Application database (users, audit, saved filters) -----------------------
# NOT configured here. On first run the app serves a /setup wizard where the
# operator picks the engine (MySQL or SQL Server) and enters credentials; they
# are written to <APP_CONFIG_DIR>/app-config.json and used from then on.
#
# Override where that file lives (defaults to ./data). Mount this directory as
# a volume in Docker so the configuration survives container restarts.
# APP_CONFIG_DIR=/var/lib/qms-dashboard

# ---- Scheduled reports -------------------------------------------------------
# Shared secret that authorizes the report-scheduler cron endpoint. Generate a
# long random value (openssl rand -hex 32). Then have the server's scheduler POST
# to /api/reports/run-due periodically (e.g. every 10 minutes) with this key:
#   Linux cron:  */10 * * * * curl -fsS -X POST -H "x-cron-key: <value>" http://localhost:3000/api/reports/run-due
#   Windows:     a Task Scheduler task running the same curl/Invoke-RestMethod.
# If unset, the endpoint is disabled (fails closed) and no scheduled reports run.
CRON_SECRET="replace-with-a-long-random-string"

# ---- Feature limits ----------------------------------------------------------
# Max rows a single Excel export may contain (protects memory).
EXPORT_MAX_ROWS=100000
# How often the live SSE stream polls the QMS live view (milliseconds).
STREAM_INTERVAL_MS=5000

# ---- Docker Compose only -----------------------------------------------------
# These are consumed by docker-compose.yml (not by the app directly). They
# provision the bundled MySQL container and choose the host port.
#
# When running via Compose, the database is reachable at hostname `db`, so set
# the QMS_DB_HOST above to `db` (and, if you use the bundled MySQL for the QMS
# side too, QMS_DB_USER=qms_user / QMS_DB_NAME=qms).
APP_PORT=3000
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
# Application database that the /setup wizard connects to. In the wizard enter:
#   engine=MySQL, host=db, port=3306, user=<APP_DB_USER>, password=<APP_DB_PASSWORD>,
#   database=<APP_DB_NAME>.
APP_DB_NAME=appdb
APP_DB_USER=app_user
APP_DB_PASSWORD=replace-with-a-strong-app-db-password
