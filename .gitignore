# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# runtime setup — created by the /setup wizard, contains DB credentials.
# Must NEVER be committed. Mount it as a volume in production instead.
/data/

# env
.env
.env.local
.env*.local

# tls — reverse-proxy certificates/keys must NEVER be committed.
# Keep the certs/ dir (and its README) but ignore any real material in it.
/deploy/nginx/certs/*
!/deploy/nginx/certs/README.md

# misc
*.pem
*.crt
*.key
.DS_Store
*.tsbuildinfo
next-env.d.ts
